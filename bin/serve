#!/usr/bin/env ruby
# frozen_string_literal: true

require 'bundler/setup'
require 'chiebukuro_mcp'
require 'ruby_knowledge_store'
require 'json'

user_config = File.expand_path('~/chiebukuro-mcp/chiebukuro.json')
repo_config = File.expand_path('../config/chiebukuro.json', __dir__)
config_path = File.exist?(user_config) ? user_config : repo_config
config      = JSON.parse(File.read(config_path, encoding: 'UTF-8'))
embedder    = RubyKnowledgeStore::Embedder.new
ChiebukuroMcp::Server.new(config: config, embedder: embedder).run
